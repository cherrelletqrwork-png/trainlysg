# Trainly environment variables
# Copy this file to `.env` locally and fill in the values.
# On Vercel, add these as Project → Settings → Environment Variables.

# --- Database ---
# Postgres connection string. Get one free at https://neon.tech
# Use the "pooled" / "pooler" URL for serverless (recommended for Vercel).
# Example: postgresql://user:pass@ep-xxx-pooler.region.aws.neon.tech/neondb?sslmode=require
DATABASE_URL="postgresql://USER:PASSWORD@HOST/DB?sslmode=require"

# (Optional) "Direct" URL for migrations only. If your provider gives you a
# separate non-pooled URL (Neon does), put it here. If not, leave it equal to DATABASE_URL.
DIRECT_URL="postgresql://USER:PASSWORD@HOST/DB?sslmode=require"

# --- Auth ---
# 32+ char random string. Generate with: openssl rand -hex 32
AUTH_SECRET="change-me-to-a-long-random-string-32-plus-characters"

# --- AI Chatbot (optional) ---
# If set, the floating "Ask Trainly" chatbot will answer with real Claude AI.
# Without it, the chatbot uses smart canned responses about Trainly (no setup needed).
# Get a key at https://console.anthropic.com
# ANTHROPIC_API_KEY="sk-ant-..."
